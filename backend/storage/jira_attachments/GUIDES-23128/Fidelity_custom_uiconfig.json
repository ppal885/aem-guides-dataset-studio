                  },
                  {
                    "component": "button",
                    "icon": "key",
                    "variant": "action",
                    "quiet": true,
                    "title": "Insert Key Definition",
                    "on-click": {
                      "name": "AUTHOR_INSERT_ELEMENT",
                      "args": "keydef"
