                    "component": "button",
                    "icon": "projectAdd",
                    "variant": "action",
                    "quiet": true,
                    "show": "@isBookmapEditMode",
                    "title": "Insert Chapter",
                    "on-click": {
                      "name": "AUTHOR_INSERT_ELEMENT",
                      "args": "chapter"
