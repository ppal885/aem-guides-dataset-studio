                  {
                    "component": "button",
                    "icon": "table",
                    "variant": "action",
                    "quiet": true,
                    "title": "Insert Table",
                    "on-click": {
                      "name": "AUTHOR_INSERT_ELEMENT",
                      "args": [
                        "simpletable",
                        "table",
                        "choicetable"
                      ]
                    }
                  },
                  {
                    "component": "button",
                    "icon": "image",
                    "variant": "action",
                    "quiet": true,
                    "title": "Insert Image",
                    "on-click": {
                      "name": "AUTHOR_INSERT_ELEMENT",
                      "args": "image"
                    }
                  },
