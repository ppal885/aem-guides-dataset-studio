                    "component": "button",
                    "icon": "filePDF",
                    "variant": "action",
                    "quiet": true,
                    "title": "Insert PDF",
                    "on-click": {
                      "name": "AUTHOR_INSERT_ELEMENT",
                      "args": "<xref href='' format = 'pdf'  otherprops = 'New Tab'></xref>"
