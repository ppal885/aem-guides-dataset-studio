# IMPORTANT: Copy to .env and fill in real values. Never commit .env or real keys.
# .env is gitignored. Use placeholders only in this example.

# HTTP port for run_local.py / uvicorn (default 8001). Use PORT=8000 if you prefer.
# Must match frontend/.env VITE_PROXY_TARGET when using the Vite proxy.
PORT=8001

# Enterprise runtime safety
# ENVIRONMENT=development | test | production
ENVIRONMENT=development
# Keep true only for local development. Production startup now rejects this.
ALLOW_DEV_AUTH_BYPASS=true
# Production must set explicit allowed origins, e.g. https://studio.internal.example
# CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Bearer auth tokens (choose one approach)
# AUTH_TOKENS_JSON={"writer-token":{"id":"writer-1","email":"writer@example.com","roles":["writer"],"allowed_tenants":["kone"]}}
# API_BEARER_TOKEN=replace_me
# ADMIN_BEARER_TOKEN=replace_me_admin

# Jira configuration (required for Index One, Plan, Generate)
JIRA_URL=https://jira.corp.adobe.com
# Or: JIRA_BASE_URL=https://jira.corp.adobe.com
JIRA_USERNAME=your_username
JIRA_PASSWORD=your_password
JIRA_PROJECT_KEY=GUIDES
# Corporate/on-prem Jira (jira.corp.adobe.com) needs v2; Jira Cloud uses v3
JIRA_API_VERSION=2

# Optional: for JQL filtering
# JIRA_ISSUE_TYPE=Bug
# COMPONENT=Automation
# EPIC_ID=DXML-10837
# SPRINT_ID=195643
# FIXED_VERSION=2504

# LLM provider: anthropic (default), bedrock, groq, or openai
# LLM_PROVIDER=anthropic

# OpenAI (set LLM_PROVIDER=openai for chat + generation to use the OpenAI API)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_openai_key
# OPENAI_MODEL=gpt-4o-mini

# Screenshot/image understanding can use a dedicated provider separate from LLM_PROVIDER.
# This is the clean setup if you want normal chat on Groq but screenshot-to-DITA on a supported vision provider.
# SCREENSHOT_VISION_PROVIDER=openai
# OPENAI_VISION_MODEL=gpt-4o-mini

# Anthropic (for plan-from-jira, generate-from-jira, and AI chat)
# A valid key and paid API usage let requests succeed; they do not by themselves change answer
# quality for a fixed model. For stronger answers, prefer a capable ANTHROPIC_MODEL and solid
# RAG (crawl/index in config/aem_guides_crawl_urls.json, RAG_* below) rather than only adding balance.
ANTHROPIC_API_KEY=your_anthropic_key_here
# Default in code if unset: claude-3-5-sonnet-20241022 (see app/services/llm_service.py)
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# SCREENSHOT_VISION_PROVIDER=anthropic
# ANTHROPIC_VISION_MODEL=claude-3-5-sonnet-20241022
# ANTHROPIC_FALLBACK_MODEL=claude-3-haiku-20240307
# LLM_FALLBACK_PROVIDER=groq

# Bedrock (Claude Code setup at Adobe - for AI chat and LLM generation)
# Use Project Turnkey credentials from CAMP, or CLAUDE_CODE_USE_BEDROCK=1
# LLM_PROVIDER=bedrock
# AWS_ACCESS_KEY_ID=your_key_from_camp
# AWS_SECRET_ACCESS_KEY=your_secret_from_camp
# AWS_REGION=us-west-2
# BEDROCK_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0

# Groq (when LLM_PROVIDER=groq) - free tier at console.groq.com
# GROQ_API_KEY=your_groq_key
# Groq chat/completions model (3.1-70b-versatile was decommissioned; use 3.3 or see Groq deprecations)
# GROQ_MODEL=llama-3.3-70b-versatile

# Jira indexing (optional)
# JIRA_INDEXING_ENABLED=false
# JIRA_INDEXING_BOOTSTRAP_ON_STARTUP=false
# JIRA_INDEXING_BOOTSTRAP_JQL=project = DXML AND updated >= -90d
# JIRA_INDEXING_BOOTSTRAP_LIMIT=1000
# JIRA_INDEXING_SCHEDULE_ENABLED=true
# JIRA_INDEXING_SCHEDULE_CRON=0 */6 * * *
# JIRA_INDEXING_SCHEDULE_JQL=project = DXML AND updated >= -7d
# JIRA_INDEXING_SCHEDULE_LIMIT=300

# Automatic scheduled jobs (optional) – enable for weekly maintenance
# Experience League crawl – weekly Sunday 3am
AEM_DOCS_CRAWL_ENABLED=true
AEM_DOCS_CRAWL_SCHEDULE=0 3 * * 0
# DITA 1.2 PDF RAG index – weekly Sunday 4am
DITA_PDF_INDEX_ENABLED=true
DITA_PDF_INDEX_SCHEDULE=0 4 * * 0

# Jira webhook (optional) - set secret and send in X-Webhook-Secret header
# JIRA_WEBHOOK_SECRET=your_webhook_secret

# RAG retrieval (chat AI and content extraction). Crawl URL list: config/aem_guides_crawl_urls.json (Oxygen DITA Style Guide + Experience League).
# Increase for more context; higher k = more chunks, larger prompts
# Semantic retrieval in restricted environments should point to a local
# SentenceTransformer directory to avoid runtime downloads from Hugging Face.
# DITA_EMBEDDING_MODEL_PATH=C:\models\all-MiniLM-L6-v2
# Optional fallback model name when a local path is not provided.
# DITA_EMBEDDING_MODEL=all-MiniLM-L6-v2
# Set true to fail closed for AEM Guides product lookup when semantic retrieval
# is unavailable, instead of silently falling back to lexical ranking.
# AEM_GUIDES_REQUIRE_SEMANTIC_RETRIEVAL=false
RAG_AEM_K=8
RAG_DITA_K=8
# Extra DITA chunks when the user asks "what is <tag>?" (AEM Guides RAG is skipped for that pattern)
RAG_DITA_K_FAQ=12
RAG_SNIPPET_CHARS=1000
RAG_CONTEXT_MAX_CHARS=6000

# Tavily web search (https://tavily.com) — augments chat + corrective RAG when configured.
# Put secrets in backend/.env OR the project-root .env (repo root); both load on backend startup. Restart uvicorn after edits.
# Keys are never read from the frontend.
# TAVILY_API_KEY=tvly-your-key-here
# Optional if TAVILY_API_KEY is unset: TAVILY_KEY=tvly-your-key-here
# Keep true so chat uses web search whenever a key is set (set to false only to disable usage)
CHAT_TAVILY_ENABLED=true
# CHAT_TAVILY_MAX_RESULTS=4
# Optional comma-separated domain allowlist (overrides defaults for chat)
# TAVILY_INCLUDE_DOMAINS=experienceleague.adobe.com,helpx.adobe.com

# GitHub DITA indexing (Oxygen userguide etc.): POST /api/v1/ai/index-github-dita-examples
# Zip from codeload.github.com; `index_all` uses primary + defaults (incl. DITA/dev_guide) + extras below.
# GITHUB_DITA_SOURCE_URL=https://github.com/oxygenxml/userguide/tree/master/DITA
# GITHUB_DITA_ADDITIONAL_SOURCE_URLS=
# Merge chunks into global aem_guides so chat RAG (retrieve_relevant_docs) sees them alongside Experience League crawl
# GITHUB_DITA_ALSO_MERGE_TO_AEM_RAG=true

# Chat: append human-precision rules (concise answers; less filler). UI toggle also sends human_prompts per message.
# CHAT_ENABLE_HUMAN_PROMPTS=true

# Chat LLM temperature (0–1). Lower = more factual/deterministic. Default in code is ~0.15.
# CHAT_TEMPERATURE=0.1

# Screenshot + reference DITA authoring — governance (audit logs, provenance, upload safety)
# CHAT_AUTHORING_AUDIT_LOG_ENABLED=true
# CHAT_AUTHORING_FAILURE_ANALYTICS_ENABLED=true
# CHAT_AUTHORING_STORE_ASSET_SHA256=true
# CHAT_AUTHORING_STRICT_IMAGE_MAGIC=true
# Prompt logging: hash_only (default) | truncated | off — truncated uses CHAT_AUTHORING_PROMPT_LOG_MAX_CHARS
# CHAT_AUTHORING_PROMPT_LOG_MODE=hash_only
# CHAT_AUTHORING_PROMPT_LOG_MAX_CHARS=0

# LLM DITA fallback (llm_generated_dita recipe): enriched Jira→concept system prompt (prolog, 4 conbody sections, mandatory attribute tables)
# LLM_DITA_USE_ENRICHED_CONCEPT_PROMPT=false

# Intent-driven DITA pipeline (generate-from-text): intent JSON → recipe selection → RAG query bundle → generation plan → semantic validation → optional repair loop
# GENERATE_FROM_TEXT_USE_INTENT_PIPELINE=false
# Max critique/regeneration rounds when validation fails (llm_generated_dita path inside intent pipeline)
# DITA_PIPELINE_MAX_REPAIRS=2

# Jira recipe pipeline: intent-based override (e.g. table alignment → table_semantics_reference instead of generic llm_generated_dita)
# PIPELINE_INTENT_ENHANCEMENT=false

# When recipe_execution_contract is passed to llm_generated_dita, abort if required constructs are missing (no silent success)
# LLM_DITA_CONTRACT_FAIL_FAST=true

# Generation debug: write scenario_dir/generation_trace.json on semantic/validation failure (default). Set true to always write.
# DITA_GENERATION_TRACE_ALWAYS=false
# Max characters of combined XML embedded in the trace file (default 96000)
# DITA_GENERATION_TRACE_MAX_XML_CHARS=96000

# Observability: LangSmith tracing for LLM calls (tokens, latency, retry)
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=your_langsmith_api_key
# LANGCHAIN_TRACING_V2=true

# Structured logging (JSON format, dita_generation_* events)
# STRUCTURED_LOGGING=true
