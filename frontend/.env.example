# Vite proxy target - backend URL for /api proxy.
# vite.config.ts defaults to http://127.0.0.1:8001 when unset (8000 is often already in use).
# Set explicitly to match run_local.py / uvicorn, then restart `npm run dev`.
# VITE_PROXY_TARGET=http://127.0.0.1:8000
# VITE_PROXY_TARGET=http://127.0.0.1:8001

# API base URL. Leave empty to use Vite proxy (dev/preview).
# If proxy fails (e.g. 404/502 on /api), set to bypass and hit backend directly:
# VITE_API_BASE_URL=http://127.0.0.1:8001
