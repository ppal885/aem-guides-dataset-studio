# Vite proxy target - backend URL for /api proxy (default: http://127.0.0.1:8000)
# Use 8001 when port 8000 is blocked: VITE_PROXY_TARGET=http://127.0.0.1:8001
# VITE_PROXY_TARGET=http://127.0.0.1:8001

# API base URL. Leave empty to use Vite proxy (dev/preview).
# If proxy fails (e.g. 404/502 on /api), set to bypass and hit backend directly:
# VITE_API_BASE_URL=http://localhost:8000
